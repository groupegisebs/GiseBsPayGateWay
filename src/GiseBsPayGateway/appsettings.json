{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=gisebs_pay_gateway;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "GiseBsPayGateway",
    "Audience": "GiseBsClientApps",
    "SecretKey": "CHANGE-THIS-TO-A-LONG-RANDOM-SECRET-KEY-MIN-32-CHARS",
    "ExpirationMinutes": 60
  },
  "ApiKey": {
    "HeaderName": "X-Api-Key",
    "AppCodeHeaderName": "X-App-Code"
  },
  "Seed": {
    "AdminEmail": "admin@gisebs.com",
    "AdminPassword": "ChangeMe123!"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*:/api/*",
        "Period": "1m",
        "Limit": 100
      }
    ]
  },
  "IpRateLimitPolicies": {},
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
