{
  "ConnectionStrings": {
    "_comment": "En production : UBUNTU1_CONNECTION_STRING via app.env (deploy). Fallback local ci-dessous.",
    "DefaultConnection": "Host=localhost;Port=5432;Database=gisebs_pay_gateway;Username=postgres;Password=postgres"
  },
  "Deployment": {
    "AppName": "GISEBS Pay Gateway",
    "ServiceName": "gisebs-pay-gateway",
    "AppRoot": "/opt/apps/gisebs-pay-gateway",
    "ListenPort": 7843,
    "PublicBaseUrl": "https://gisebsapipaygateway.gisebs.com"
  },
  "Jwt": {
    "Issuer": "GiseBsPayGateway",
    "Audience": "GiseBsClientApps",
    "SecretKey": "CHANGE-THIS-TO-A-LONG-RANDOM-SECRET-KEY-MIN-32-CHARS",
    "ExpirationMinutes": 60
  },
  "ApiKey": {
    "HeaderName": "X-Api-Key",
    "AppCodeHeaderName": "X-App-Code"
  },
  "Seed": {
    "AdminEmail": "bediga.jean@gisebs.com",
    "AdminPassword": "Goodeeg!35578",
    "TestEmail": "bediga.jean@gmail.com",
    "TestPassword": "Mcd!35578"
  },
  "CurrencyConversion": {
    "AutoCreatePlanVariant": true,
    "UseLiveRates": true,
    "LiveRatesCacheMinutes": 60,
    "BankOfCanadaUrl": "https://www.bankofcanada.ca/valet/observations/group/FX_RATES_DAILY/json?recent=1",
    "RatesToCad": {
      "cad": 1,
      "usd": 1.36,
      "eur": 1.48,
      "gbp": 1.72,
      "chf": 1.55,
      "jpy": 0.0092,
      "aud": 0.90,
      "nzd": 0.82,
      "cny": 0.19,
      "hkd": 0.17,
      "sgd": 1.02,
      "inr": 0.016,
      "krw": 0.0010,
      "sek": 0.13,
      "nok": 0.13,
      "mxn": 0.075,
      "brl": 0.25,
      "zar": 0.075,
      "pln": 0.34,
      "thb": 0.039,
      "myr": 0.31,
      "twd": 0.042,
      "try": 0.040,
      "idr": 0.000085,
      "pen": 0.37
    }
  },
  "PendingPaymentExpiry": {
    "Enabled": true,
    "ExpiryHours": 24,
    "IntervalMinutes": 60,
    "BatchSize": 100
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*:/api/*",
        "Period": "1m",
        "Limit": 100
      }
    ]
  },
  "IpRateLimitPolicies": {},
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PayPal": {
    "Enabled": false,
    "UseSandbox": true,
    "ClientId": "",
    "ClientSecret": "",
    "OAuthRedirectUri": "https://gisebsapipaygateway.gisebs.com/api/paypal/oauth/callback",
    "TokenEncryptionKey": ""
  },
  "PayoutCallbacks": {
    "SharedSecret": ""
  }
}
