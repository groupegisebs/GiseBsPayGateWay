@page
@model ErrorModel
@{
    ViewData["Title"] = "Erreur";
    Layout = "_Layout";
}

<div class="text-center py-5">
    <h1 class="text-danger mb-3">Une erreur est survenue</h1>
    <p class="lead text-muted">Impossible de traiter votre demande. L'équipe technique a été notifiée via les logs.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-4">
            <strong>ID de requête :</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="mt-4">
        <a class="btn btn-primary" asp-page="/Admin/Index">Retour au tableau de bord</a>
    </div>
</div>
