@page
@model GiseBsPayGateway.Pages.Admin.Invoices.IndexModel
@{
    ViewData["Title"] = "Factures";
    Layout = "_Layout";
}

<h1 class="mb-4">Factures</h1>

<p class="text-muted mb-4">
    Factures enregistrées automatiquement lors des paiements réussis et des renouvellements d'abonnement Stripe.
</p>

<partial name="_AdminListToolbar" model="Model.Pagination" />

<table class="table table-striped table-sm align-middle">
    <thead>
        <tr>
            <th>Date</th>
            <th>N° facture</th>
            <th>Application</th>
            <th>Client</th>
            <th>Produit</th>
            <th>Plan</th>
            <th>Montant</th>
            <th>Statut</th>
            <th>Payé le</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Invoices)
    {
        <tr>
            <td>@item.InvoiceDate.ToString("g")</td>
            <td><code>@item.InvoiceCode</code></td>
            <td>@item.AppName</td>
            <td>
                <div>@item.CustomerCode</div>
                <small class="text-muted">@item.CustomerEmail</small>
            </td>
            <td>@item.ProductName</td>
            <td><code>@item.PlanCode</code></td>
            <td>@item.Amount.ToString("N2") @item.Currency.ToUpper()</td>
            <td>
                <span class="badge @(item.Status == "Paid" ? "text-bg-success" : item.Status == "Failed" ? "text-bg-danger" : "text-bg-secondary")">
                    @item.Status
                </span>
            </td>
            <td>@(item.PaidAt?.ToString("g") ?? "—")</td>
            <td>
                <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Détails</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (!Model.Invoices.Any())
{
    <div class="alert alert-info">Aucune facture enregistrée pour le moment.</div>
}
