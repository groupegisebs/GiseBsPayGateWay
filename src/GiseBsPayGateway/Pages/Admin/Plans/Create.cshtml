@page
@model GiseBsPayGateway.Pages.Admin.Plans.CreateModel
@{
    ViewData["Title"] = Model.IsCopyMode ? "Copier un plan" : "Nouveau plan";
    Layout = "_Layout";
}

<h1 class="mb-3">@(Model.IsCopyMode ? "Copier un plan tarifaire" : "Nouveau plan tarifaire")</h1>

@if (Model.IsCopyMode)
{
    <div class="alert alert-info mb-4">
        Copie du plan <strong>« @Model.CopySourcePlanCode »</strong>. Ajustez le tarif si besoin puis enregistrez.
        Le nouveau plan sera <strong>activé</strong> automatiquement.
    </div>
}
else
{
    <div class="alert alert-warning mb-4">
        Un plan créé ne peut <strong>jamais être modifié</strong>. Pour changer un tarif, désactivez l'ancien plan
        puis utilisez <strong>Copier</strong> sur la liste.
    </div>
}

<div class="alert alert-info py-2 mb-4">
    Sélectionnez un <strong>code plan standard</strong> (<code>MONTHLY</code>, <code>YEARLY</code>, <code>ONE-TIME</code>).
    L'intervalle Stripe est appliqué automatiquement.
</div>

<form method="post" class="col-md-6">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="Input.ProductId" class="form-label"></label>
        <select asp-for="Input.ProductId" asp-items="Model.Products" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Input.PlanCode" class="form-label"></label>
        <select asp-for="Input.PlanCode" asp-items="Model.PlanCodes" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Name" class="form-label"></label>
        <input asp-for="Input.Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Input.Amount" class="form-label"></label>
        <input asp-for="Input.Amount" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Input.Currency" class="form-label"></label>
        <select asp-for="Input.Currency" asp-items="Model.Currencies" class="form-select"></select>
    </div>
    <button type="submit" class="btn btn-primary">Créer</button>
    <a asp-page="Index" class="btn btn-secondary">Annuler</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
