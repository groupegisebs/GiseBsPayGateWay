@page
@model GiseBsPayGateway.Pages.Admin.Plans.CreateModel
@{
    ViewData["Title"] = "Nouveau plan";
    Layout = "_Layout";
}

<h1 class="mb-3">Nouveau plan tarifaire</h1>

<div class="alert alert-warning mb-4">
    Un plan créé ne peut <strong>jamais être modifié</strong>. Pour changer un tarif, désactivez l'ancien plan
    depuis la liste et créez-en un nouveau (même code plan possible si l'ancien est inactif).
</div>

<form method="post" class="col-md-6">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="Input.ProductId" class="form-label"></label>
        <select asp-for="Input.ProductId" asp-items="Model.Products" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Input.PlanCode" class="form-label"></label>
        <input asp-for="Input.PlanCode" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Input.Name" class="form-label"></label>
        <input asp-for="Input.Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Input.Amount" class="form-label"></label>
        <input asp-for="Input.Amount" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Input.Currency" class="form-label"></label>
        <input asp-for="Input.Currency" class="form-control" value="eur" />
    </div>
    <div class="mb-3">
        <label asp-for="Input.BillingInterval" class="form-label"></label>
        <select asp-for="Input.BillingInterval" asp-items="Html.GetEnumSelectList<GiseBsPayGateway.Enums.BillingInterval>()" class="form-select"></select>
    </div>
    <button type="submit" class="btn btn-primary">Créer</button>
    <a asp-page="Index" class="btn btn-secondary">Annuler</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
