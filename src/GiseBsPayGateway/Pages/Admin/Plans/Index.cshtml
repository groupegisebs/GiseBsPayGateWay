@page
@model GiseBsPayGateway.Pages.Admin.Plans.IndexModel
@{
    ViewData["Title"] = "Plans tarifaires";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Plans tarifaires</h1>
    <a asp-page="Create" class="btn btn-primary">Nouveau plan</a>
</div>

<div class="alert alert-info py-2 mb-4">
    Les plans tarifaires sont <strong>immuables</strong> : ils ne peuvent pas être modifiés.
    Pour changer un tarif, <strong>désactivez</strong> l'ancien plan puis <strong>copiez-le</strong> ou créez-en un nouveau.
    <strong>Copier</strong> ouvre le formulaire de création prérempli ; le nouveau plan sera <strong>activé</strong> à l'enregistrement.
</div>

@if (TempData["PlanMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["PlanError"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Produit</th>
            <th>Code plan</th>
            <th>Nom</th>
            <th>Montant</th>
            <th>Intervalle</th>
            <th>Stripe Price ID</th>
            <th>Statut</th>
            <th>Créé le</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Plans)
    {
        <tr class="@(item.IsActive ? "" : "table-secondary text-muted")">
            <td>@item.ProductName</td>
            <td><code>@item.PlanCode</code></td>
            <td>@item.Name</td>
            <td>@item.Amount.ToString("N2") @item.Currency.ToUpper()</td>
            <td>@item.BillingInterval</td>
            <td><small>@(item.StripePriceId ?? "—")</small></td>
            <td>
                @if (item.IsActive)
                {
                    <span class="badge text-bg-success">Actif</span>
                }
                else
                {
                    <span class="badge text-bg-secondary">Inactif</span>
                }
            </td>
            <td><small>@item.CreatedAt.ToString("g")</small></td>
            <td class="text-nowrap">
                <a asp-page="Create" asp-route-copyFrom="@item.Id"
                   class="btn btn-sm btn-outline-primary me-1" title="Ouvrir en mode création">
                    Copier
                </a>
                <form method="post" asp-page-handler="ToggleActive" class="d-inline">
                    <input type="hidden" name="planId" value="@item.Id" />
                    @if (item.IsActive)
                    {
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Désactiver ce plan ? Les nouveaux paiements ne pourront plus l\'utiliser.');">
                            Désactiver
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-sm btn-outline-success">Activer</button>
                    }
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
