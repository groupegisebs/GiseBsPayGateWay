@page
@model GiseBsPayGateway.Pages.Admin.Products.IndexModel
@{
    ViewData["Title"] = "Produits";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Produits</h1>
    <a asp-page="Create" class="btn btn-primary">Nouveau produit</a>
</div>

@if (TempData["ProductMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["ProductError"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<partial name="_AdminListToolbar" model="Model.Pagination" />

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Application</th>
            <th>Code</th>
            <th>Nom</th>
            <th>Stripe Product ID</th>
            <th>Actif</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Products)
    {
        <tr>
            <td>@item.AppName</td>
            <td><code>@item.ProductCode</code></td>
            <td>@item.Name</td>
            <td><small>@(item.StripeProductId ?? "—")</small></td>
            <td>@(item.IsActive ? "Oui" : "Non")</td>
            <td class="text-nowrap">
                @if (item.IsActive)
                {
                    <form method="post" asp-page-handler="SyncStripe" class="d-inline">
                        <input type="hidden" name="productId" value="@item.Id" />
                        <input type="hidden" name="page" value="@Model.PageNumber" />
                        <input type="hidden" name="search" value="@Model.Search" />
                        <button type="submit" class="btn btn-sm btn-outline-primary"
                                title="Créer ou mettre à jour le produit et les plans actifs dans Stripe">
                            Sync Stripe
                        </button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
