@page
@model GiseBsPayGateway.Pages.Admin.Transactions.IndexModel
@using GiseBsPayGateway.Enums
@{
    ViewData["Title"] = "Transactions";
    Layout = "_Layout";
}

<h1 class="mb-4">Historique des paiements</h1>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-5">
        <label class="form-label">Recherche</label>
        <input type="search" name="search" value="@Model.Search" class="form-control" placeholder="Code, app, client, produit, Stripe…" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Statut</label>
        <select name="status" class="form-select">
            <option value="">Tous</option>
            @foreach (PaymentStatus s in Enum.GetValues<PaymentStatus>())
            {
                <option value="@s" selected="@(string.Equals(Model.StatusFilter, s.ToString(), StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-outline-secondary">Filtrer</button>
        @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.StatusFilter))
        {
            <a asp-page="./Index" class="btn btn-link">Effacer</a>
        }
    </div>
</form>

@if (Model.Pagination.TotalCount > 0)
{
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <small class="text-muted">@Model.Pagination.StartItem–@Model.Pagination.EndItem sur @Model.Pagination.TotalCount</small>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            @if (Model.PendingCount > 0)
            {
                <form method="post" asp-page-handler="DeleteAllPending"
                      onsubmit="return confirm('Supprimer jusqu\'à 200 transactions Pending (filtre actuel) ?');">
                    <input type="hidden" name="Search" value="@Model.Search" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">Purger Pending (@Model.PendingCount)</button>
                </form>
            }
            @if (Model.Pagination.TotalPages > 1)
            {
                <nav aria-label="Pagination">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.Pagination.HasPrevious ? "" : "disabled")">
                            <a class="page-link" href="@Model.Pagination.PageUrl(Model.Pagination.Page - 1)">‹</a>
                        </li>
                        @for (var p = 1; p <= Model.Pagination.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Pagination.Page ? "active" : "")">
                                <a class="page-link" href="@Model.Pagination.PageUrl(p)">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Pagination.HasNext ? "" : "disabled")">
                            <a class="page-link" href="@Model.Pagination.PageUrl(Model.Pagination.Page + 1)">›</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
}

<table class="table table-striped table-sm align-middle">
    <thead>
        <tr>
            <th>Date</th>
            <th>Code paiement</th>
            <th>Facture GISEBS</th>
            <th>Application</th>
            <th>Client</th>
            <th>Produit</th>
            <th>Montant HT</th>
            <th>Total TTC</th>
            <th>Taxes</th>
            <th>Frais Stripe</th>
            <th>Net</th>
            <th>Statut</th>
            <th>Stripe PI</th>
            <th>Payé le</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Transactions)
    {
        var badge = item.Status == "Pending" ? "text-bg-warning"
            : item.Status == "Succeeded" ? "text-bg-success"
            : item.Status == "Failed" ? "text-bg-danger"
            : "text-bg-secondary";
        <tr>
            <td>@item.CreatedAt.ToString("g")</td>
            <td>
                <a asp-page="./Details" asp-route-id="@item.Id"><code>@item.PaymentCode</code></a>
            </td>
            <td>@(string.IsNullOrWhiteSpace(item.InvoiceNumber) ? "—" : Html.Raw($"<code>{item.InvoiceNumber}</code>"))</td>
            <td>@item.AppName</td>
            <td><small>@item.CustomerCode</small></td>
            <td>@item.ProductCode</td>
            <td>@item.Amount.ToString("N2") @item.Currency.ToUpper()</td>
            <td>@(item.TotalAmount?.ToString("N2") ?? "—") @(item.TotalAmount.HasValue ? item.Currency.ToUpper() : "")</td>
            <td>@(item.TaxAmount?.ToString("N2") ?? "—")</td>
            <td>@(item.StripeFee?.ToString("N2") ?? "—")</td>
            <td>@(item.NetAmount?.ToString("N2") ?? "—")</td>
            <td><span class="badge @badge">@item.Status</span></td>
            <td><small>@(item.StripePaymentIntentId ?? "—")</small></td>
            <td>@(item.PaidAt?.ToString("g") ?? "—")</td>
            <td class="text-nowrap">
                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Détails</a>
            </td>
        </tr>
    }
    </tbody>
</table>
