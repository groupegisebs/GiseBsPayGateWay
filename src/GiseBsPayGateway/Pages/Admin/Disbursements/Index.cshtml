@page
@model GiseBsPayGateway.Pages.Admin.Disbursements.IndexModel
@{
    ViewData["Title"] = "Décaissements vendeurs";
    Layout = "_Layout";
}

<h1 class="mb-3" style="color: var(--gisebs-magenta-darker);">Décaissements — revue &amp; rapprochement</h1>
<p class="text-muted">
    Les demandes arrivent de BoutiqueGise (Stripe Connect, PayPal, Mobile Money).
    <strong>Validez le rapprochement</strong> avant d’exécuter le paiement.
</p>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-warning">@err</div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                <tr>
                    <th>Créé</th>
                    <th>App</th>
                    <th>Vendeur</th>
                    <th>Canal</th>
                    <th>Destination</th>
                    <th class="text-end">Montant</th>
                    <th>Pays</th>
                    <th>Statut</th>
                    <th>Rapprochement</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="small">@item.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td>@(item.ClientApplication?.AppCode ?? "—")</td>
                        <td>
                            <div>@(item.SellerDisplayName ?? item.SellerExternalId)</div>
                            <div class="small text-muted">@item.ExternalReference</div>
                        </td>
                        <td><span class="badge text-bg-secondary">@item.ProviderCode</span></td>
                        <td>@item.DestinationMasked</td>
                        <td class="text-end">@((item.AmountMinor / 100m).ToString("N2")) @item.Currency.ToUpperInvariant()</td>
                        <td>@item.CountryCode</td>
                        <td>@item.Status</td>
                        <td>@(item.ReconciliationChecked ? "✓" : "—")</td>
                        <td class="text-nowrap">
                            @if (!item.ReconciliationChecked)
                            {
                                <form method="post" asp-page-handler="Reconcile" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="notes" value="Rapprochement OK" />
                                    <button class="btn btn-sm btn-outline-primary" type="submit">Rapprocher</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Pay" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-sm btn-success" type="submit">Payer</button>
                                </form>
                            }
                            <form method="post" asp-page-handler="Hold" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="reason" value="hold" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Hold</button>
                            </form>
                            <form method="post" asp-page-handler="Reject" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="reason" value="rejected" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">Refuser</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="10" class="text-muted p-4">Aucune demande en attente.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="alert alert-info mt-3 small">
    <strong>Mobile Money / Orange Money / Wave / M-Pesa :</strong>
    le vendeur ne fournit que des infos publiques (titulaire + numéro).
    Aucun PIN/OTP n’est stocké. Après rapprochement, le statut « Payé » confirme la caisse / l’agrégateur.
    <br />
    <strong>PayPal :</strong> OAuth + Payouts API si <code>PayPal:Enabled</code> est configuré dans les secrets ; sinon le paiement échouera avec un message clair.
</div>
