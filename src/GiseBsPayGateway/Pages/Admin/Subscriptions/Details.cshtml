@page "{id:guid}"
@model GiseBsPayGateway.Pages.Admin.Subscriptions.DetailsModel
@using GiseBsPayGateway.Enums
@{
    ViewData["Title"] = $"Abonnement {Model.Subscription.SubscriptionCode}";
    Layout = "_Layout";
    var sub = Model.Subscription;
    var statusClass = Model.EffectiveStatus switch
    {
        SubscriptionStatus.Active => "text-bg-success",
        SubscriptionStatus.Trialing => "text-bg-info",
        SubscriptionStatus.PastDue => "text-bg-warning",
        SubscriptionStatus.Cancelled => "text-bg-secondary",
        SubscriptionStatus.Unpaid => "text-bg-danger",
        _ => "text-bg-secondary"
    };
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}
@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">Abonnement <code>@sub.SubscriptionCode</code></h1>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="badge @statusClass">@Model.EffectiveStatus</span>
            @if (Model.IsScheduledToEnd)
            {
                <span class="badge text-bg-warning">Actif jusqu'au @sub.CurrentPeriodEnd?.ToString("g")</span>
            }
            @if (Model.AmountFromStripe)
            {
                <span class="badge text-bg-info">Montant Stripe</span>
            }
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <form method="post" asp-page-handler="RefreshFromStripe" asp-route-id="@sub.Id">
            <button type="submit" class="btn btn-outline-primary">
                Actualiser depuis Stripe
            </button>
        </form>
        <a asp-page="./Index" class="btn btn-secondary">Retour à la liste</a>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card mb-4">
            <div class="card-header">Détails</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Créé le</dt>
                    <dd class="col-sm-8">@sub.CreatedAt.ToString("f")</dd>
                    <dt class="col-sm-4">Période courante</dt>
                    <dd class="col-sm-8">
                        @if (sub.CurrentPeriodStart.HasValue && sub.CurrentPeriodEnd.HasValue)
                        {
                            <span>@sub.CurrentPeriodStart?.ToString("g") → @sub.CurrentPeriodEnd?.ToString("g")</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </dd>
                    <dt class="col-sm-4">Annulé le</dt>
                    <dd class="col-sm-8">@(sub.CancelledAt?.ToString("f") ?? "—")</dd>
                    <dt class="col-sm-4">Fin d'accès</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsScheduledToEnd)
                        {
                            <strong>@sub.CurrentPeriodEnd?.ToString("f")</strong>
                            <div class="small text-muted">Reste actif jusqu'à cette date, puis se termine automatiquement.</div>
                        }
                        else if (Model.EffectiveStatus == SubscriptionStatus.Cancelled)
                        {
                            <span>Terminé</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </dd>
                    <dt class="col-sm-4">Cancel at period end</dt>
                    <dd class="col-sm-8">@(Model.IsScheduledToEnd || sub.CancelAtPeriodEnd ? "Oui" : "Non")</dd>
                    <dt class="col-sm-4">Stripe Subscription</dt>
                    <dd class="col-sm-8"><code>@(sub.StripeSubscriptionId ?? "—")</code></dd>
                </dl>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">Produit & plan</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Application</dt>
                    <dd class="col-sm-8">@Model.AppName <small class="text-muted">(@Model.AppCode)</small></dd>
                    <dt class="col-sm-4">Produit</dt>
                    <dd class="col-sm-8"><code>@Model.ProductCode</code> — @Model.ProductName</dd>
                    <dt class="col-sm-4">Plan</dt>
                    <dd class="col-sm-8"><code>@Model.PlanCode</code> — @Model.PlanName</dd>
                    <dt class="col-sm-4">Montant abonnement</dt>
                    <dd class="col-sm-8">
                        <strong class="fs-5">@Model.DisplayAmount.ToString("N2") @Model.DisplayCurrency.ToUpperInvariant()</strong>
                        @if (Model.AmountFromStripe)
                        {
                            <span class="badge text-bg-info ms-1">Stripe</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary ms-1">Plan local</span>
                        }
                        <div class="small text-muted">
                            Plan catalogue : @Model.PlanAmount.ToString("N2") @Model.PlanCurrency.ToUpperInvariant()
                            @if (Model.StripeSyncedAt.HasValue)
                            {
                                <span>· Dernière sync Stripe @Model.StripeSyncedAt.Value.ToString("g")</span>
                            }
                        </div>
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Historique des paiements</span>
                <span class="badge text-bg-secondary">@Model.PaymentHistory.Count</span>
            </div>
            <div class="card-body p-0">
                @if (Model.PaymentHistory.Count == 0)
                {
                    <p class="p-3 mb-0 text-muted">Aucun paiement ou facture enregistré pour cet abonnement.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Référence</th>
                                    <th>Période</th>
                                    <th class="text-end">HT</th>
                                    <th class="text-end">Taxes</th>
                                    <th class="text-end">Total</th>
                                    <th>Statut</th>
                                    <th>Payé le</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var p in Model.PaymentHistory)
                            {
                                var total = p.GrossAmount ?? p.Amount;
                                var ht = p.GrossAmount.HasValue && p.TaxAmount.HasValue
                                    ? total - p.TaxAmount.Value
                                    : p.Amount;
                                var statusBadge = p.Status is "Paid" or "Succeeded" ? "text-bg-success"
                                    : p.Status is "Failed" ? "text-bg-danger"
                                    : p.Status is "Pending" or "Open" ? "text-bg-warning"
                                    : "text-bg-secondary";
                                <tr>
                                    <td><small>@p.Date.ToString("g")</small></td>
                                    <td><span class="badge text-bg-light border">@p.Kind</span></td>
                                    <td>
                                        @if (p.Kind == "Facture")
                                        {
                                            <a asp-page="/Admin/Invoices/Details" asp-route-id="@p.LinkId"><code>@p.Reference</code></a>
                                        }
                                        else
                                        {
                                            <a asp-page="/Admin/Transactions/Details" asp-route-id="@p.LinkId"><code>@p.Reference</code></a>
                                        }
                                    </td>
                                    <td><small>@(p.Period ?? "—")</small></td>
                                    <td class="text-end">@ht.ToString("N2")</td>
                                    <td class="text-end">@(p.TaxAmount?.ToString("N2") ?? "—")</td>
                                    <td class="text-end">
                                        <strong>@total.ToString("N2")</strong>
                                        <span class="text-muted">@p.Currency.ToUpperInvariant()</span>
                                    </td>
                                    <td><span class="badge @statusBadge">@p.Status</span></td>
                                    <td><small>@(p.PaidAt?.ToString("g") ?? "—")</small></td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card mb-4">
            <div class="card-header">Client</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Code</dt>
                    <dd class="col-sm-8"><code>@Model.CustomerCode</code></dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8"><a href="mailto:@Model.CustomerEmail">@Model.CustomerEmail</a></dd>
                    <dt class="col-sm-4">Nom</dt>
                    <dd class="col-sm-8">@(Model.CustomerName ?? "—")</dd>
                    <dt class="col-sm-4">Téléphone</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrWhiteSpace(Model.CustomerPhone))
                        {
                            <a href="tel:@Model.CustomerPhone">@Model.CustomerPhone</a>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </dd>
                    <dt class="col-sm-4">Stripe Customer</dt>
                    <dd class="col-sm-8"><code>@(Model.StripeCustomerId ?? "—")</code></dd>
                </dl>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">Actions</div>
            <div class="card-body d-grid gap-2">
                @if (Model.CanReactivate)
                {
                    <form method="post" asp-page-handler="Reactivate" asp-route-id="@sub.Id"
                          onsubmit="return confirm('Réactiver cet abonnement ?');">
                        <button type="submit" class="btn btn-success w-100">
                            Réactiver l'abonnement
                        </button>
                    </form>
                    <p class="small text-muted mb-0">
                        @if (Model.IsScheduledToEnd)
                        {
                            <span>Retire l'annulation : l'abonnement continue au-delà de la période.</span>
                        }
                        else
                        {
                            <span>Stripe ne permet pas de redémarrer un abonnement canceled : un nouvel abonnement sera créé.</span>
                        }
                    </p>
                    <hr />
                }

                @if (Model.CanScheduleCancel)
                {
                    <form method="post" asp-page-handler="ScheduleCancel" asp-route-id="@sub.Id"
                          onsubmit="return confirm('Programmer l\'annulation à la fin de la période ? L\'accès reste actif jusqu\'au @sub.CurrentPeriodEnd?.ToString("g").');">
                        <button type="submit" class="btn btn-warning w-100">
                            Annuler (fin de période)
                        </button>
                    </form>
                    <p class="small text-muted mb-0">
                        L'abonnement reste <strong>actif jusqu'au @(sub.CurrentPeriodEnd?.ToString("g") ?? "fin de période")</strong>, puis se termine.
                    </p>
                }

                @if (Model.CanUndoSchedule)
                {
                    <form method="post" asp-page-handler="UndoSchedule" asp-route-id="@sub.Id"
                          onsubmit="return confirm('Retirer la programmation d\'annulation ?');">
                        <button type="submit" class="btn btn-outline-success w-100">
                            Annuler la programmation
                        </button>
                    </form>
                }

                @if (Model.CanDeleteLocal)
                {
                    <hr />
                    <form method="post" asp-page-handler="DeleteLocal" asp-route-id="@sub.Id"
                          onsubmit="return confirm('Supprimer cet enregistrement local ? Les factures/paiements restent conservés.');">
                        <button type="submit" class="btn btn-danger w-100">
                            Supprimer l'enregistrement local
                        </button>
                    </form>
                }

                @if (!Model.CanReactivate && !Model.CanScheduleCancel && !Model.CanUndoSchedule && !Model.CanDeleteLocal)
                {
                    <p class="text-muted mb-0">Aucune action disponible pour ce statut.</p>
                }
            </div>
        </div>
    </div>
</div>
