@page
@model GiseBsPayGateway.Pages.Admin.CollectedTaxes.IndexModel
@{
    ViewData["Title"] = "Taxes collectées";
    Layout = "_Layout";
}

<h1 class="mb-4">Taxes collectées</h1>

<partial name="_AdminListToolbar" model="Model.Pagination" />

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Date</th>
            <th>Code paiement</th>
            <th>Réf. transaction</th>
            <th>Application</th>
            <th>Pays</th>
            <th>Province</th>
            <th>Ville</th>
            <th>Sous-total</th>
            <th>Taxes</th>
            <th>Total</th>
            <th>Détail</th>
            <th>Stripe Tax Tx</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Records)
    {
        <tr>
            <td>@item.CollectedAt.ToString("g")</td>
            <td><code>@item.PaymentCode</code></td>
            <td><small>@item.TransactionReference</small></td>
            <td>@item.AppName</td>
            <td>@(item.BillingCountry ?? "—")</td>
            <td>@(item.BillingState ?? "—")</td>
            <td>@(item.BillingCity ?? "—")</td>
            <td>@item.AmountSubtotal.ToString("N2") @item.Currency.ToUpper()</td>
            <td>@item.TaxAmountTotal.ToString("N2")</td>
            <td>@item.GrossAmount.ToString("N2")</td>
            <td><small>@item.TaxSummary</small></td>
            <td><small>@(item.StripeTaxTransactionId ?? "—")</small></td>
        </tr>
    }
    </tbody>
</table>
