@page
@model GiseBsPayGateway.Pages.Admin.AuditLogs.IndexModel
@{
    ViewData["Title"] = "Journal d'audit";
    Layout = "_Layout";
}

<h1 class="mb-4">Journal d'audit</h1>

<partial name="_AdminListToolbar" model="Model.Pagination" />

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Date</th>
            <th>Action</th>
            <th>Entité</th>
            <th>Utilisateur</th>
            <th>AppCode</th>
            <th>IP</th>
            <th>Succès</th>
            <th>Détails</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Logs)
    {
        <tr>
            <td>@item.CreatedAt.ToString("g")</td>
            <td>@item.Action</td>
            <td>@item.EntityType</td>
            <td>@item.UserName</td>
            <td>@item.AppCode</td>
            <td>@item.IpAddress</td>
            <td>@(item.IsSuccess ? "Oui" : "Non")</td>
            <td><small>@item.Details</small></td>
        </tr>
    }
    </tbody>
</table>
