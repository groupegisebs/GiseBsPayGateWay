@page
@model GiseBsPayGateway.Pages.Admin.Applications.IndexModel
@{
    ViewData["Title"] = "Applications clientes";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Applications clientes</h1>
    <a asp-page="Create" class="btn btn-primary">Nouvelle application</a>
</div>

@if (!string.IsNullOrEmpty(Model.LoadError))
{
    <div class="alert alert-danger">@Model.LoadError</div>
}

@if (Model.NewApiKey is not null)
{
    <div class="alert alert-warning">
        <strong>Clé API générée (copiez-la maintenant, elle ne sera plus affichée) :</strong>
        <code>@Model.NewApiKey</code>
    </div>
}
else if (TempData["NewApiKey"] is string tempKey)
{
    <div class="alert alert-warning">
        <strong>Clé API générée (copiez-la maintenant, elle ne sera plus affichée) :</strong>
        <code>@tempKey</code>
    </div>
}

<partial name="_AdminListToolbar" model="Model.Pagination" />

<table class="table table-striped">
    <thead>
        <tr>
            <th>AppCode</th>
            <th>Nom</th>
            <th>Domaines autorisés</th>
            <th>Actif</th>
            <th>Clés API</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var app in Model.Applications)
    {
        <tr>
            <td><code>@app.AppCode</code></td>
            <td>@app.Name</td>
            <td>@app.AllowedDomains</td>
            <td>@(app.IsActive ? "Oui" : "Non")</td>
            <td>@app.ApiKeyCount</td>
            <td>
                <form method="post" asp-page-handler="GenerateKey" class="d-inline">
                    <input type="hidden" name="applicationId" value="@app.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Générer clé API</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
