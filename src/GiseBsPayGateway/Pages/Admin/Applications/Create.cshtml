@page
@model GiseBsPayGateway.Pages.Admin.Applications.CreateModel
@{
    ViewData["Title"] = "Nouvelle application";
    Layout = "_Layout";
}

<h1 class="mb-4">Nouvelle application cliente</h1>

<form method="post" class="col-md-6">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="Input.AppCode" class="form-label"></label>
        <input asp-for="Input.AppCode" class="form-control" />
        <span asp-validation-for="Input.AppCode" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Name" class="form-label"></label>
        <input asp-for="Input.Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Input.Description" class="form-label"></label>
        <textarea asp-for="Input.Description" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label asp-for="Input.AllowedDomains" class="form-label"></label>
        <input asp-for="Input.AllowedDomains" class="form-control" placeholder="localhost,example.com" />
    </div>
    <button type="submit" class="btn btn-primary">Créer</button>
    <a asp-page="Index" class="btn btn-secondary">Annuler</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
