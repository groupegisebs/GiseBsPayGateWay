@page
@model GiseBsPayGateway.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Tableau de bord";
    Layout = "_Layout";
}

<h1 class="mb-4" style="color: var(--gisebs-magenta-darker);">Tableau de bord</h1>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card stat-revenue">
            <div class="card-body">
                <h6 class="card-subtitle mb-2">Revenus totaux</h6>
                <h3 class="card-title">@Model.Stats.TotalRevenue.ToString("C")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card stat-success">
            <div class="card-body">
                <h6 class="card-subtitle mb-2">Paiements réussis</h6>
                <h3 class="card-title">@Model.Stats.SuccessfulPayments</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card stat-failed">
            <div class="card-body">
                <h6 class="card-subtitle mb-2">Paiements échoués</h6>
                <h3 class="card-title">@Model.Stats.FailedPayments</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card stat-subs">
            <div class="card-body">
                <h6 class="card-subtitle mb-2">Abonnements actifs</h6>
                <h3 class="card-title">@Model.Stats.ActiveSubscriptions</h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card stat-neutral">
            <div class="card-body">
                <h5 class="text-muted">Applications clientes</h5>
                <p class="display-6 mb-0">@Model.Stats.ClientApplications</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-neutral">
            <div class="card-body">
                <h5 class="text-muted">Paiements en attente</h5>
                <p class="display-6 mb-0">@Model.Stats.PendingPayments</p>
            </div>
        </div>
    </div>
</div>
