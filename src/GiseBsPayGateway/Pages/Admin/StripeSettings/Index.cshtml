@page
@model GiseBsPayGateway.Pages.Admin.StripeSettings.IndexModel
@{
    ViewData["Title"] = "Configuration Stripe";
    Layout = "_Layout";
}

<h1 class="mb-4">Configuration Stripe</h1>

@if (Model.CurrentSettings is not null)
{
    <div class="alert alert-info">
        Configuration active : mode @(Model.CurrentSettings.IsLiveMode ? "Production" : "Test") —
        clé publique <code>@Model.MaskedPublishableKey</code>
    </div>
}

<form method="post" class="col-md-8">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="Input.PublishableKey" class="form-label"></label>
        <input asp-for="Input.PublishableKey" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Input.SecretKey" class="form-label"></label>
        <input asp-for="Input.SecretKey" class="form-control" type="password" autocomplete="new-password" />
        <div class="form-text">La clé secrète n'est jamais affichée en clair dans les logs.</div>
    </div>
    <div class="mb-3">
        <label asp-for="Input.WebhookSecret" class="form-label"></label>
        <input asp-for="Input.WebhookSecret" class="form-control" type="password" autocomplete="new-password" />
    </div>
    <div class="mb-3 form-check">
        <input asp-for="Input.IsLiveMode" class="form-check-input" />
        <label asp-for="Input.IsLiveMode" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">Enregistrer</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
