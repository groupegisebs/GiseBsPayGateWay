@model GiseBsPayGateway.Pages.Admin.AdminPaginationInfo

<form method="get" class="row g-2 align-items-center mb-3">
    <div class="col-sm-auto flex-grow-1">
        <input type="search" name="search" value="@Model.Search" class="form-control" placeholder="Rechercher..." />
    </div>
    <div class="col-sm-auto">
        <button type="submit" class="btn btn-outline-secondary">Rechercher</button>
    </div>
    @if (!string.IsNullOrEmpty(Model.Search))
    {
        <div class="col-sm-auto">
            <a href="?" class="btn btn-link">Effacer</a>
        </div>
    }
</form>

@if (Model.TotalCount > 0)
{
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <small class="text-muted">
            @Model.StartItem–@Model.EndItem sur @Model.TotalCount
        </small>
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                        <a class="page-link" href="@Model.PageUrl(Model.Page - 1)" aria-label="Précédent">‹</a>
                    </li>
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" href="@Model.PageUrl(p)">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.HasNext ? "" : "disabled")">
                        <a class="page-link" href="@Model.PageUrl(Model.Page + 1)" aria-label="Suivant">›</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
}
