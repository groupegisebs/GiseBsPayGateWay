<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GISEBS Pay Gateway</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark gisebs-navbar mb-4">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-page="/Admin/Index">GISEBS Pay Gateway</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMain">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Index">Tableau de bord</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Applications/Index">Applications</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Products/Index">Produits</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Plans/Index">Plans</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Transactions/Index">Transactions</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Subscriptions/Index">Abonnements</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Webhooks/Index">Webhooks</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/StripeSettings/Index">Stripe</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/AuditLogs/Index">Audit</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Guide/Index">Guide</a></li>
                        </ul>
                        <form asp-page="/Account/Logout" method="post" class="d-flex">
                            <button type="submit" class="btn btn-outline-light btn-sm">Déconnexion</button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
