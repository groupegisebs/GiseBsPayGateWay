@page
@model GiseBsPayGateway.Pages.IndexModel
@{
    ViewData["Title"] = "Accueil";
    Layout = "_Layout";
}

<div class="text-center py-5">
    <h1 class="display-4">GISEBS Pay Gateway</h1>
    <p class="lead">Service centralisé de paiement Stripe pour HoloTuto, CogniDoc, WarrantySafe et les futures applications GISEBS.</p>
    <div class="mt-4">
        <a class="btn btn-primary btn-lg me-2" asp-page="/Account/Login">Administration</a>
        @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
        {
            <a class="btn btn-outline-secondary btn-lg" href="/swagger">API Swagger</a>
        }
    </div>
</div>
