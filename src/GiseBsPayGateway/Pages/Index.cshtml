@page
@model GiseBsPayGateway.Pages.IndexModel
@{
    ViewData["Title"] = "Accueil";
    Layout = "_Layout";
}

<div class="gisebs-hero text-center">
    <h1 class="display-5 mb-3">GISEBS Pay Gateway</h1>
    <p class="lead text-muted mx-auto" style="max-width: 640px;">
        Service centralisé de paiement Stripe pour HoloTuto, CogniDoc, WarrantySafe et les futures applications GISEBS.
    </p>
    <div class="mt-4">
        <a class="btn btn-primary btn-lg me-2 px-4" asp-page="/Account/Login">Administration</a>
        @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
        {
            <a class="btn btn-outline-primary btn-lg px-4" href="/swagger">API Swagger</a>
        }
    </div>
</div>
